# ─────────────────────────────────────────────────────────────────────────────

# Staging environment — copy to .env.staging and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# IP-адрес или домен вашего сервера (без http://)
# Например: 192.168.1.100  или  staging.myapp.com
SERVER_HOST=YOUR_SERVER_IP

# ── База данных ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── JWT-секреты (генерировать: openssl rand -hex 32) ─────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_32chars
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars

# ── MinIO (S3-совместимое хранилище файлов) ───────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me_minio_password

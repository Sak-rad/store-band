# App
NODE_ENV=production
PORT=3001
CLIENT_URL=https://example.com
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,ru

# Database
 DATABASE_URL=postgresql://postgres:postgres@localhost:5432/relocation_platform

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_ACCESS_SECRET=ydcf8471b475afe20c0b67729f849d518d36f5f1150c625c3b611c1367117f8a25e4cfdd64ffd1bb80484c18c25b09eeb93ead444e3c45a936eda39156c48fe53
JWT_REFRESH_SECRET=2d19cbc9fbf7bc8187cdb599dfda1b4da6550406298728463b2d6236846477b5e66c096707cad04179d8d533ef82018440818e62bd35be62cc402cc5990e4ba4
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# S3 / Cloudflare R2
S3_BUCKET=relocation-platform
S3_REGION=auto
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_PUBLIC_URL=https://cdn.example.com

# Email (Resend)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@example.com

# Telegram Mini App
TELEGRAM_BOT_TOKEN=your-bot-token

# Next.js
NEXT_PUBLIC_API_URL=https://example.com/api
NEXT_PUBLIC_WS_URL=wss://example.com
NEXT_PUBLIC_DEFAULT_LOCALE=en

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  PROVIDER
  ADMIN
}

enum AccountProvider {
  GOOGLE
  VK
  TELEGRAM
  APPLE
}

enum ContextType {
  LISTING
  SERVICE
  TOUR
  VEHICLE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum NotificationType {
  NEW_MESSAGE
  BOOKING_REQUEST
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  REVIEW_RECEIVED
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  passwordHash    String?
  name            String?
  avatarUrl       String?
  role            UserRole  @default(USER)
  preferredLocale String    @default("en")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  provider      Provider?
  bookings      Booking[]
  reviews       Review[]
  favorites     Favorite[]
  notifications Notification[]
  chatsAsUser  Chat[]     @relation("ChatUser")
  sentMessages Message[]

  @@index([email])
}

model Session {
  id           Int      @id @default(autoincrement())
  userId       Int
  refreshToken String   @unique
  userAgent    String?
  ip           String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

model Account {
  id           Int             @id @default(autoincrement())
  userId       Int
  provider     AccountProvider
  providerId   String
  accessToken  String?
  refreshToken String?
  createdAt    DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
}

// ─── Provider ─────────────────────────────────────────────────────────────────

model Provider {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  nameI18n    Json
  name        String
  bioI18n     Json?
  bio         String?
  avatarUrl   String?
  phone       String?
  website     String?
  isVerified  Boolean  @default(false)
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings Listing[]
  reviews  Review[]
  chats    Chat[]    @relation("ChatProvider")

  @@index([userId])
}

// ─── Location ─────────────────────────────────────────────────────────────────

model Country {
  id       Int    @id @default(autoincrement())
  nameI18n Json
  name     String
  code     String @unique

  cities   City[]
  listings Listing[]

  @@index([code])
}

model City {
  id        Int    @id @default(autoincrement())
  nameI18n  Json
  name      String
  countryId Int

  country  Country   @relation(fields: [countryId], references: [id])
  listings Listing[]

  @@index([countryId])
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id       Int     @id @default(autoincrement())
  nameI18n Json
  name     String
  slug     String  @unique
  icon     String?
  parentId Int?

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  listings Listing[]

  @@index([slug])
  @@index([parentId])
}

// ─── Listing ──────────────────────────────────────────────────────────────────

model Listing {
  id              Int       @id @default(autoincrement())
  titleI18n       Json
  descriptionI18n Json
  title           String
  description     String
  priceMin        Decimal   @db.Decimal(12, 2)
  priceMax        Decimal?  @db.Decimal(12, 2)
  priceOnRequest  Boolean   @default(false)
  currency        String    @default("USD")
  lat             Float?
  lng             Float?
  address         String?
  categoryId      Int
  cityId          Int
  countryId       Int
  providerId      Int
  listingType     String    @default("rent")
  isPublished     Boolean   @default(false)
  isFeatured      Boolean   @default(false)
  rating          Float     @default(0)
  reviewCount     Int       @default(0)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  category  Category       @relation(fields: [categoryId], references: [id])
  city      City           @relation(fields: [cityId], references: [id])
  country   Country        @relation(fields: [countryId], references: [id])
  provider  Provider       @relation(fields: [providerId], references: [id])
  media     ListingMedia[]
  bookings  Booking[]
  reviews   Review[]
  favorites Favorite[]
  chats     Chat[]

  @@index([cityId, categoryId])
  @@index([providerId])
  @@index([countryId])
  @@index([isPublished, deletedAt])
  @@index([isFeatured])
}

model ListingMedia {
  id        Int     @id @default(autoincrement())
  listingId Int
  url       String
  thumbUrl  String?
  type      String  @default("image")
  order     Int     @default(0)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

// ─── Chat ─────────────────────────────────────────────────────────────────────

model Chat {
  id          Int          @id @default(autoincrement())
  userId      Int
  providerId  Int
  listingId   Int?
  contextType ContextType?
  contextId   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user     User      @relation("ChatUser", fields: [userId], references: [id], onDelete: Cascade)
  provider Provider  @relation("ChatProvider", fields: [providerId], references: [id], onDelete: Cascade)
  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  messages Message[]

  @@unique([userId, providerId, listingId])
  @@index([userId])
  @@index([providerId])
}

model Message {
  id               Int      @id @default(autoincrement())
  chatId           Int
  senderId         Int
  text             String
  readBy           Int[]    @default([])
  replyToMessageId Int?
  isPinned         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  chat    Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender  User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo Message? @relation("MessageReply", fields: [replyToMessageId], references: [id])
  replies Message[] @relation("MessageReply")

  @@index([chatId, createdAt])
  @@index([senderId])
}

// ─── Booking ──────────────────────────────────────────────────────────────────

model Booking {
  id                 Int           @id @default(autoincrement())
  userId             Int
  listingId          Int
  checkIn            DateTime
  checkOut           DateTime
  bookingDate        DateTime      @default(now())
  guestCount         Int           @default(1)
  totalPrice         Decimal       @db.Decimal(12, 2)
  currency           String        @default("USD")
  status             BookingStatus @default(PENDING)
  paymentStatus      PaymentStatus @default(UNPAID)
  cancellationReason String?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, checkIn, checkOut])
  @@index([userId])
  @@index([status])
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id         Int      @id @default(autoincrement())
  userId     Int
  listingId  Int?
  providerId Int?
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  provider Provider? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([listingId])
  @@index([providerId])
  @@index([userId])
}

// ─── Favorite ─────────────────────────────────────────────────────────────────

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  listingId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  titleKey  String
  bodyKey   String
  params    Json?
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}
